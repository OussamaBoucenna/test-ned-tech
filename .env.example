# --- Database ---
# Connection string used by Prisma when running the API locally (not in Docker).
# Note: host port matches POSTGRES_PORT below (5433 here to avoid clashing with a
# local Postgres on 5432). Use 5432 if nothing else occupies it.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/employee_directory?schema=public

# Credentials consumed by docker-compose to provision the Postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=employee_directory
# Host port the container is published on (container always listens on 5432)
POSTGRES_PORT=5433

# --- API (apps/api) ---
PORT=3000
# 'production' makes the auth cookie Secure (HTTPS-only)
NODE_ENV=development
# Secret used to sign JWTs — change in any real environment
JWT_SECRET=change_me
# Token lifetime; also drives the auth cookie maxAge (e.g. 1d, 12h, 30m)
JWT_EXPIRES_IN=1d
# Comma-separated list of origins allowed by CORS (must match the UI origin
# exactly — credentials/cookies require an explicit origin, not '*')
CORS_ORIGIN=http://localhost:5173

# --- Web (apps/web) ---
# Base URL the React app (browser) uses to reach the API
VITE_API_BASE_URL=http://localhost:3000/api

# --- Docker Compose ---
# When running `docker compose up`, the API/web services read the variables
# above (POSTGRES_*, JWT_*, etc.) from this file. The API reaches Postgres via
# the internal hostname `db`, so its DATABASE_URL is built from POSTGRES_* and
# does not use the localhost value above.
