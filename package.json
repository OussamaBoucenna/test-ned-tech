{
  "name": "employee-directory",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight employee directory application (technical assessment)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run start:dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/api && npm run build --workspace apps/web",
    "db:up": "docker compose up -d db",
    "db:migrate": "npm run prisma:migrate --workspace apps/api",
    "db:seed": "npm run prisma:seed --workspace apps/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
